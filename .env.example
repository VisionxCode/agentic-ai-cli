OPENROUTER_API_KEY=your_openrouter_api_key_here
# Must support image input because both agents receive SDK input_image payloads.
OPENROUTER_MODEL=qwen/qwen3.6-plus
OPENROUTER_AGENT_MAX_TURNS=30

# Optional: override the shared model per agent.
# OPENROUTER_CODER_MODEL=openai/gpt-4o
# OPENROUTER_EVALUATOR_MODEL=openai/gpt-4o

# Optional OpenRouter metadata.
OPENROUTER_HTTP_REFERER=http://localhost
OPENROUTER_APP_TITLE=IBM Hackathon Agent Workflow

# Optional OpenRouter provider routing.
# Leave these empty to use OpenRouter's default provider settings.
OPENROUTER_PROVIDER_ORDER=
OPENROUTER_PROVIDER_ONLY=
OPENROUTER_PROVIDER_IGNORE=
OPENROUTER_PROVIDER_ALLOW_FALLBACKS=
OPENROUTER_PROVIDER_REQUIRE_PARAMETERS=
OPENROUTER_PROVIDER_DATA_COLLECTION=
OPENROUTER_PROVIDER_ZDR=
OPENROUTER_PROVIDER_ENFORCE_DISTILLABLE_TEXT=
OPENROUTER_PROVIDER_QUANTIZATIONS=
OPENROUTER_PROVIDER_SORT=

# Optional: enables MiniMax MCP web/search tools for the coder agent.
MINIMAX_API_KEY=sk-cp-OQB1bANH3ZrwnkSaE0rl_xBqW2dCqU2KsJaaNiZZApT064gVovT3Im30pF7vGTF1-VEBFMMrbmylAAoNyG9TkeRD9gYinReETKYFSvZ3_ZPHLNoenP6dpbY
MINIMAX_API_HOST=https://api.minimax.io
